# .credentials.template
# 复制为 .credentials 后按需填写真实值。未使用的区域可以留空。
#
# 用法建议：
# 1. cp .credentials.template .credentials
# 2. 只填写你实际启用的技能所需配置
# 3. 部分脚本会直接读取 .credentials（例如 WECHAT_*、XIANYU_COOKIE）
# 4. 其余变量通常需要在使用前执行：
#      set -a
#      source .credentials
#      set +a
#    或复制到对应技能目录自己的 .env 文件
# 5. .credentials 已被 .gitignore 忽略，不要把真实凭证写回仓库

# =========================================================
# 1) OpenClaw / 模型 / 网关
# =========================================================

# OpenClaw 主模型密钥（推荐）
CLAUDE_API_KEY=

# 兼容备用模型（可选）
GEMINI_API_KEY=
OPENAI_API_KEY=

# 网关测试 / API 调用时使用（可选）
OPENCLAW_AUTH_TOKEN=
OPENCLAW_GATEWAY_URL=http://localhost:18789

# =========================================================
# 2) 微信公众号链路
# 直接被 scripts/wechat_draft.py 读取
# =========================================================

WECHAT_APPID=
WECHAT_APPSECRET=

# 可选：不填时当前脚本会回退到默认作者名
WECHAT_AUTHOR=
WECHAT_DEFAULT_AUTHOR=

# =========================================================
# 3) 小红书链路
# skills/小红书笔记技能包/ 的 publish_xhs.py 主要读取环境变量
# 浏览器模式常配合 cookies.json 使用；这里作为中心记录位
# =========================================================

XHS_COOKIE=
XHS_API_URL=http://localhost:5005
XHS_HOME=$HOME/xhs_workspace/xiaohongshu-send

# =========================================================
# 4) 闲鱼链路
# 根目录脚本直接读取 XIANYU_COOKIE
# skills/xianyu-multi-agent/ 还可能需要把下面变量同步到它自己的 .env
# =========================================================

# 根目录闲鱼脚本使用
XIANYU_COOKIE=

# skills/xianyu-multi-agent/ 可用；通常可与 XIANYU_COOKIE 填同一份 Cookie
COOKIES_STR=
XIANYU_HOME=

# 若本机已配置 OpenClaw，xianyu-multi-agent 可不单独填写 API_KEY
API_KEY=
MODEL_BASE_URL=
MODEL_NAME=openai-codex/gpt-5.4

# 扣子买家智能体（按需启用）
COZE_API_KEY=
COZE_BASE_URL=https://api.coze.cn
COZE_BUYER_BOT_ID=

# 本地 Web / 加密相关（按需启用）
FLASK_SECRET_KEY=change-me-before-public-web
ENCRYPTION_KEY=

# =========================================================
# 5) 投资技能 / GitHub 自动化
# skills/ai-invest-agent/scripts/set_github_topics.sh 等脚本使用
# =========================================================

GITHUB_TOKEN=

# =========================================================
# 6) Obsidian / 文章归档
# scripts/wechat_article_to_obsidian.py 使用
# =========================================================

OBSIDIAN_VAULT=

# =========================================================
# 7) 未来新增技能扩展
# 新增技能时，优先按“技能名 / 用途 / 是否必填”补到这里
# 例如：
# NEW_SKILL_API_KEY=
# NEW_SKILL_BASE_URL=
# =========================================================
